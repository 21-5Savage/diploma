{
  "name": "Miniconda Rootless version",
  // Build settings
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  // Resource limits (optional)
  // Use these if you want to protect the dev server from a single container eating everything.
  // Adjust values per project/team policy.
  "runArgs": [
    "--cpus=2",
    "--memory=8g",
    "--network=host"
  ],
  //this port will be where your program will be able exposed on. change as needed
  "forwardPorts": [
    //9998,
    //9999,
  ],
  // Rootless Docker + workspace permissions:
  // - We run as "root" inside the container, but with rootless Docker this is NOT real host root.
  // - updateRemoteUserUID makes the container user mapping align with the host user so mounts are writable.
  "remoteUser": "root",
  "containerUser": "root",
  "updateRemoteUserUID": true,
  // Point docker CLI in the container to the host user's rootless Docker socket
  "mounts": [
    "source=${localEnv:XDG_RUNTIME_DIR},target=${localEnv:XDG_RUNTIME_DIR},type=bind",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly"
  ],
  "containerEnv": {
    "DOCKER_HOST": "unix://${localEnv:XDG_RUNTIME_DIR}/docker.sock",
    "HOME": "/root",
    "GIT_SSH_COMMAND": "ssh -o IdentitiesOnly=yes"
    // "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "workspaceMountConsistency": "cached",
  // Port forwarding (optional)
  // If your app listens on a port inside the container (e.g., 8000/8080/3000),
  // list it here to make it accessible from your local machine through VS Code.
  // "forwardPorts": [8000, 8080, 3000],
  // VS Code customization (optional)
  "customizations": {
    "vscode": {
      // Set *default* container specific settings.json values on container create.
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/vscode/bin/python",
        "python.languageServer": "Pylance",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "notebook.formatOnSave.enabled": true,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": true
        },
        "files.autoSave": "afterDelay",
        "files.trimTrailingWhitespace": true,
        "files.trimFinalNewlines": true,
        "files.insertFinalNewline": true,
        "files.exclude": {
          "**/__pycache__": true,
          "**/*.~sql": true,
          "**/.ipynb_checkpoints": true
        },
        "jupyter.jupyterServerType": "local",
        "jupyter.notebookFileRoot": "workspaceFolder"
      },
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-docker",
        "withfig.fig",
        "openai.chatgpt"
        // Add team/project extensions here, e.g.:
        // "ms-python.vscode-pylance",
        // "charliermarsh.ruff",
        // "tamasfe.even-better-toml"
      ]
    }
  },
  // Runs after the container is created (first time) / rebuilt (depending on VS Code behavior)
  "postCreateCommand": "umask 0002 && conda env update -n vscode -f environment.yml"
  // "postCreateCommand": "pip3 --disable-pip-version-check --no-cache-dir install -r requirements.txt",
}
